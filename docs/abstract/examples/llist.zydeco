data LList(A) where
  | LNil( )
  | LCons(A, Thunk(Ret(LList(A))))

def rec foldr : Thunk(
  Thunk(A -> Thunk(B) -> B) -> 
  Thunk(Ret(LList(A))) -> Thunk(B) -> B
) = {
  fn (step, ll, b) ->
    do llv <- ! ll;
    match llv
    | LNil( ) -> ! b
    | LCons(hd, tl) ->
      ! step hd { ! foldr step tl b }
};